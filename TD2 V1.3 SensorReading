                lcd.locate(0,16);
                lcd.printf("Right Encoder Value %d", rightEncoder.countRead());
                wait_us(100000);

                break;

            case sensorReading:

                if(sensorConstant == 0){
                    sens1.readOnVoltage();
                    sens2.readOffVoltage();
                    sens3.readOnVoltage();
                    sens4.readOffVoltage();
                    sens5.readOnVoltage();
                }
