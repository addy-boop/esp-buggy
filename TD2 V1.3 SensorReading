Timeout debounceTimer;
const float debounceTime = 0.10f;       //100ms

//sensors
DigitalOut group1Enable(PC_11);
DigitalOut group2Enable(PC_9);

//Functions Start

//forward declaration of enableStateSwitch needed as call each other

void enableStateSwitch();

//next state ISR

void nextState(){

    //interrupt disable for debounce
  
  
    up.rise(NULL);

    switch(state){
        case(startUp):
            state = encoderRead;
        break;
        case(encoderRead):
            state = sensorReading;
        break;
        case(sensorReading):
            state = startUp;
        break;
    }

    //debounce
    debounceTimer.attach(&enableStateSwitch, debounceTime);
}




void stop_motors() {
    pwmLeft.write(1.0f);
    pwmRight.write(1.0f);
    enable = 0;
}

void move_forward() {
    // Reset counts before moving
    leftEncoder.countreset();
    rightEncoder.countreset();

    // Set direction - both forward
    directionRight = 1;
    directionLeft = 1;

    while (leftEncoder.countRead() < target_counts) {
        pwmLeft.write(0.81f);
        pwmRight.write(0.8f);
        enable = 1;
    }

    stop_motors();
    
}

void turn_right_90() {

    leftEncoder.countreset();
    rightEncoder.countreset();

    directionRight = 0;  // both motors move forwards.
    directionLeft = 1;

    pwmLeft.period(0.0002f);
    pwmRight.period(0.0002f);


    while (leftEncoder.countRead() < right_turn_90_counts) {
        pwmLeft.write(0.81f);
        pwmRight.write(0.8f);
        enable = 1;
    }


    stop_motors();
}

void turn_left_90() {

    leftEncoder.countreset();
    rightEncoder.countreset();

    directionRight = 1;  // move forwards
    directionLeft = 0;

    pwmLeft.period(0.0002f);
    pwmRight.period(0.0002f);

    while (leftEncoder.countRead() < left_turn_90_counts) {
      pwmLeft.write(0.81f);
      pwmRight.write(0.8f);
      enable = 1;
     }

    stop_motors();

}

//Encoder intterupt function, uses a timed interrupt to check at set frequency --> interrupt calls another 

//debouncing function

void enableStateSwitch(){
    up.rise(&nextState);
}

//bluetooth state change function

void bluetoothIRS(){
    if(hm10.readable()){
        s = hm10.getc(); // s =hm10.getc();
        if (s == 'B'){
            LED = !LED;
        }
        if(s == 'A'){
            switch(state){
                case(startUp):
                    state = encoderRead;
                break;
                case(encoderRead):
                    state = sensorReading;
                break;
                case(sensorReading):
                    state = startUp;
                break;
                }
            }
        }
}


// main() runs in its own thread in the OS
int main()
{

    up.rise(&nextState);   

    //encoderCount leftEncoder(PB_9);
