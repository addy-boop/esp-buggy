class encoderCount{

private:
    InterruptIn countInterrupt;
    volatile int count;
    volatile int overallCount;
    volatile float rotationTime;
    Timer countTimer;

public:
    encoderCount(PinName pin):
    countInterrupt(pin), count(0), rotationTime(0.0f), overallCount(0){
        countInterrupt.rise(callback(this, &encoderCount::increment));
    }

    void increment(){
        count++;
        if(count == 1){
            countTimer.reset();
            countTimer.start();
        };
        /*if(count == 256){
            countTimer.stop();
            rotationTime = (countTimer.read()/256);
            //count = 0;
            overallCount++;
        };*/
    }

    int countRead(){
        return count;
    }

    float countRotationTime(){
        return rotationTime;
    }

    int totalRotations(){
        return overallCount;
    }

    void countreset() {
       count = 0;
}
 

};


class sensors: public AnalogIn{

    private:
    float onVoltage, offVoltage, nRVoltage;
    char colour;

    public:
    sensors(PinName pin):
    AnalogIn(pin), onVoltage(0.0f), offVoltage(0.0f), nRVoltage(0.0f){
    
    }

    void readOnVoltage(){
        onVoltage = read();
    }

    void readOffVoltage(){
        offVoltage = read();
    }

    float readNRVoltage(){
        nRVoltage = onVoltage - offVoltage;
        return nRVoltage;
    }

    void colourCheck(){
        if(nRVoltage > 0.1f){       //0.1 needs to be average black emitter on value;
            colour = 'W';
        }
        else{
            colour = 'B';
        }
    }
};


