DigitalOut rightPol(PA_10);
int leftCounter = 0;
int rightCounter = 0;
int target_counts = 509;
int right_turn_90_counts = 165;     //varations needed due to horizontal oscillations of gear box causing oscillatory wheel movement++++++++
