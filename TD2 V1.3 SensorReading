                lcd.locate(0,10);
                lcd.printf("Sensor 5 Reading: %.2f", sens5.readNRVoltage());
                lcd.locate(0,20);
                lcd.printf("Sensor 3 Reading: %.2f", sens3.readNRVoltage());

                sensorConstant = !sensorConstant;

                group1Constant = !group1Constant;      //switches the enables for groups
                group2Constant = !group2Constant;

                group1Enable.write(group1Constant);
                group2Enable.write(group2Constant);

                wait_us(100000000);
            
            }
        }


    }

