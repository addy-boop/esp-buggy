    int sensorConstant = 0;
    int group1Constant = 0;
    int group2Constant = 1;

    while (true) {

         
    //main state code insert here

        switch (state) {
            case startUp:
                if (state != lastState){
                    enable = 0;
                    pwmRight.write(1.0f);       //turns them off
                    pwmLeft.write(1.0f);
                    lcd.cls();
                    lcd.locate(0,0);
                    lcd.printf("Start Screen");
                    
                }
