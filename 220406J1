void controller () {
    directionLeft = 1;
    directionRight = 1;

    //group 1

    group1Enable.write(1);
    group2Enable.write(0);
    wait_us(200);
    sens1.readOnVoltage();
    sens2.readOffVoltage();
    sens3.readOnVoltage();
    sens4.readOffVoltage();
    sens5.readOnVoltage();
    
    //group 2
    group1Enable.write(0);
    group2Enable.write(1);
    wait_us(200);
    sens1.readOffVoltage();
    sens2.readOnVoltage();
    sens3.readOffVoltage();
    sens4.readOnVoltage();
    sens5.readOffVoltage();

    float s1 = sens1.readNRVoltage();
    float s2 = sens2.readNRVoltage();
    float s3 = sens3.readNRVoltage();
    float s4 = sens4.readNRVoltage();
    float s5 = sens5.readNRVoltage();

    float stopTolerance = 0.1f;

    //check to see if a stop needs to occur

   /* if(
        s1<=(s2+stopTolerance)&&s1>=(s2-stopTolerance)&&
        s1<=(s3+stopTolerance)&&s1>=(s3-stopTolerance)&&
        s1<=(s4+stopTolerance)&&s1>=(s4-stopTolerance)&&
        s1<=(s5+stopTolerance)&&s1>=(s5-stopTolerance)){        //idea to increase counts to x amount and if reached then stop the buggy

        stopCountCheck += 1;
        if (stopCountCheck == 10){
            stop_motors();
            state = startUp;
            return;
        }
        }
    else {
        stopCountCheck = 0;
    }*/


    //float error_vel = speed - leftEncoder.velocityRead();
    float error_pos;

    float sum = s1+s2+s3+s4+s5;
    if(sum >0.05f){
        error_pos = ((2.0f*s1) + (1.0f*s2) + (0.0f*s3) + (-1.0f*s4) + (-2.0f*s5)) / (s1+s2+s3+s4+s5);
    
    }else{
        error_pos = 0.0f;
    }
    float correction = Kp*error_pos; //this is for the proportional of the position.

    derror_pos = error_pos - preverror_pos;
    float d_pos = derror_pos/dt;

    float steering = correction + Kd*d_pos;
    if (steering >0.7f){
        steering = 0.7f;
    }
    else if (steering < -0.7f) {
        steering = -0.7f;
    }

    ltarget_vel = 0.2f - steering; //slow the left
    rtarget_vel = 0.2f + steering; //make right faster

    error_vel_left = ltarget_vel - leftEncoder.velocityRead();
    error_vel_right = rtarget_vel - rightEncoder.velocityRead();

    //now implement PI for the velocity.
    integral_left += error_vel_left * dt;
    integral_right += error_vel_right * dt;

    if(integral_left > 1.0f) integral_left = 1.0f;
    if(integral_left < -1.0f) integral_left = -1.0f;

    if(integral_right > 1.0f) integral_right = 1.0f;
    if(integral_right < -1.0f) integral_right = -1.0f;

    float leftControl = Kp_vel * error_vel_left + Ki_vel * integral_left;
    float rightControl = Kp_vel * error_vel_right + Ki_vel * integral_right;

    float pwmLeft_val = 0.62 + leftControl;
    float pwmRight_val = 0.62 + rightControl;

    if(pwmLeft_val > 0.95f) pwmLeft_val = 0.95f; //for clamping the speed between certain values.
    if(pwmLeft_val < 0.55f) pwmLeft_val = 0.55f;

    if(pwmRight_val > 0.95f) pwmRight_val = 0.95f;
    if(pwmRight_val < 0.55f) pwmRight_val = 0.55f;

    pwmLeft.write(pwmLeft_val);
    pwmRight.write(pwmRight_val);
    enable = 1;

    //pwmLeft.write(pwmValue);
    preverror_pos = error_pos;

}


