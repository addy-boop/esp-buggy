class encoderCount{

private:
    InterruptIn countInterrupt;
    volatile int count;
    volatile int overallCount;
    volatile float rotationTime, velocity;
    Timer countTimer;

public:
    encoderCount(PinName pin):
    countInterrupt(pin), count(0), rotationTime(0.0f), overallCount(0), velocity(0){
        countInterrupt.rise(callback(this, &encoderCount::increment));
    }

    void increment(){
        count++;
        if(count == 1){
            countTimer.reset();
            countTimer.start();
        };
        if(count == 255){
            countTimer.stop();
            rotationTime = (countTimer.read());
            count = 0;
            //overallCount++;
        };
    }

    
    float velocityRead(){
        velocity = ((3.14159f * (79.0f/1000.0f))/rotationTime);
        return velocity;
    }

    int countRead(){
        return count;
    }

    float countRotationTime(){
        return rotationTime;
    }

    int totalRotations(){
        return overallCount;
    }

    void countreset() {
       count = 0;
}
 

};

class sensors: public AnalogIn{

    private:
    float onVoltage, offVoltage, nRVoltage;
    char colour;

    public:
    sensors(PinName pin):
    AnalogIn(pin), onVoltage(0.0f), offVoltage(0.0f), nRVoltage(0.0f), colour('B'){
    
    }

    void readOnVoltage(){
        onVoltage = read();
        onVoltage = 2*onVoltage;
    }

    void readOffVoltage(){
        offVoltage = read();
        offVoltage = 2*offVoltage;
    }

    float readNRVoltage(){
        nRVoltage = -1*(onVoltage - offVoltage);
        return (nRVoltage);
    }

    void colourCheck(){
        if(nRVoltage > 0.3f){       //0.1 needs to be average black emitter on value;
            colour = 'W';
        }
        else{
            colour = 'B';
        }
    }

    char colourRead(){
        return colour;
    }
};

