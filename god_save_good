#include "mbed.h"
#include "C12832.h"
#include "MPU6050.h"

class encoderCount{

private:
    InterruptIn countInterrupt;
    volatile int count;
    volatile int overallCount;
    volatile float rotationTime, velocity;
    Timer countTimer;

public:
    encoderCount(PinName pin):
    countInterrupt(pin), count(0), rotationTime(0.0f), overallCount(0), velocity(0){
        countInterrupt.rise(callback(this, &encoderCount::increment));
    }

    void increment(){
        count++;
        if(count == 1){
            countTimer.reset();
            countTimer.start();
        }
        if(count == 150){
            countTimer.stop();
            rotationTime = countTimer.read();
            count = 0;
        }
    }
    
    float velocityRead(){
        if(rotationTime <= 0.0001f){
            return velocity;
        }
        velocity = ((3.14159f * (79.0f/1000.0f))/rotationTime);
        return velocity;
    }

    int countRead(){
        return count;
    }

    void countreset() {
        count = 0;
    }
};

class sensors: public AnalogIn{

private:
    float onVoltage, offVoltage, nRVoltage;
    char colour;

public:
    sensors(PinName pin):
    AnalogIn(pin), onVoltage(0.0f), offVoltage(0.0f), nRVoltage(0.0f), colour('B'){}

    void readOnVoltage(){
        onVoltage = read();
        onVoltage = 2 * onVoltage;
    }

    void readOffVoltage(){
        offVoltage = read();
        offVoltage = 2 * offVoltage;
    }

    float readNRVoltage(){
        nRVoltage = onVoltage - offVoltage;
        return nRVoltage;
    }

    char colourRead(){
        return colour;
    }
};

// global variables

C12832 lcd(D11,D13,D12,D7,D10);

PwmOut pwmRight(PB_7);
PwmOut pwmLeft(PB_1);

InterruptIn up(A2);

DigitalOut enable(PD_2);
DigitalOut directionLeft(PB_14);
DigitalOut directionRight(PC_12);
DigitalOut leftPol(PB_15);
DigitalOut rightPol(PC_10);

int target_counts = 509;
int right_turn_90_counts = 165;
int left_turn_90_counts = 170;

encoderCount leftEncoder(PC_6);
encoderCount rightEncoder(PC_8);

float derror_pos;
float preverror_pos;
float Kd = 0.000f;
float Kp = 3.6f;

float ltarget_vel;
float rtarget_vel;
float integral_left;
float integral_right;
float error_vel_left;
float error_vel_right;

float Kp_vel = 0.4f;
float Ki_vel = 0.20f;

// Bluetooth
Serial hm10(PA_11, PA_12);
char s;
DigitalOut LED(D5);

// states
typedef enum{
    startUp,
    preControl,
    turnaroundState,
    controlState
} programState;

volatile programState state;
volatile programState lastState;

// sensors
DigitalOut group1Enable(PC_11);
DigitalOut group2Enable(PC_9);

sensors sens1(PC_5);
sensors sens2(PC_4);
sensors sens3(PA_4);
sensors sens4(PB_0);
sensors sens5(PC_1);
sensors backSens(PC_0);

// IMU
MPU6050 mpu(PB_9, PB_8);
volatile float yaw = 0.0f;
volatile float zGyro = 0.0f;

bool do180Turn = false;

int stopCountCheck = 0;

// functions

bool turnCheck180(){
    return (yaw >= 69.5f || yaw <= -69.5f);
}

void stop_motors() {
    pwmLeft.write(1.0f);
    pwmRight.write(1.0f);
    enable = 0;
}

void bluetoothIRS(){
    if(hm10.readable()){
        s = hm10.getc();

        if(s == 'T'){
            if(state == startUp){
                state = preControl;
            }
        }

        if(s == 'B'){
            LED = !LED;
        }
    }
}

void controller () {
    const float basePwm = 0.45f;
    const float minPwm = 0.10f;
    const float maxPwm = 0.95f;
    const float maxSteering = 0.95f;

    directionLeft = 1;
    directionRight = 1;

    static Timer controlTimer;
    static bool firstRun = true;

    if(firstRun){
        controlTimer.start();
        firstRun = false;
        return;
    }

    float controlDt = controlTimer.read();
    controlTimer.reset();
    controlTimer.start();

    if(controlDt <= 0.0f || controlDt > 0.5f){
        return;
    }

    group1Enable.write(1);
    group2Enable.write(0);
    wait_us(200);

    sens1.readOnVoltage();
    sens2.readOffVoltage();
    sens3.readOnVoltage();
    sens4.readOffVoltage();
    sens5.readOnVoltage();

    group1Enable.write(0);
    group2Enable.write(1);
    wait_us(200);

    sens1.readOffVoltage();
    sens2.readOnVoltage();
    sens3.readOffVoltage();
    sens4.readOnVoltage();
    sens5.readOffVoltage();

    float s1 = sens1.readNRVoltage();
    float s2 = sens2.readNRVoltage();
    float s3 = sens3.readNRVoltage();
    float s4 = sens4.readNRVoltage();
    float s5 = sens5.readNRVoltage();

    float sum = s1 + s2 + s3 + s4 + s5;

    if(s1 < 0.2f &&
       s2 < 0.2f &&
       s3 < 0.2f &&
       s4 < 0.2f &&
       s5 < 0.3f) {

        stopCountCheck += 1;

        if(stopCountCheck == 100){
            stop_motors();
            state = startUp;
            return;
        }
    }
    else {
        stopCountCheck = 0;
    }

    float error_pos;

    if(sum > 0.5f){
        error_pos = ((2.0f*s1) + (1.0f*s2) + (0.0f*s3) + (-1.0f*s4) + (-2.0f*s5)) / sum;
    }
    else{
        error_pos = 0.0f;
    }

    float correction = Kp * error_pos;

    derror_pos = error_pos - preverror_pos;
    float d_pos = derror_pos / controlDt;

    float steering = correction + Kd * d_pos;

    if(steering > maxSteering){
        steering = maxSteering;
    }
    else if(steering < -maxSteering){
        steering = -maxSteering;
    }

    ltarget_vel = 1.2f + steering;
    rtarget_vel = 1.2f - steering;

    error_vel_left = ltarget_vel - leftEncoder.velocityRead();
    error_vel_right = rtarget_vel - rightEncoder.velocityRead();

    integral_left += error_vel_left * controlDt;
    integral_right += error_vel_right * controlDt;

    if(integral_left > 1.0f) integral_left = 1.0f;
    if(integral_left < -1.0f) integral_left = -1.0f;

    if(integral_right > 1.0f) integral_right = 1.0f;
    if(integral_right < -1.0f) integral_right = -1.0f;

    float leftControl = Kp_vel * error_vel_left + Ki_vel * integral_left;
    float rightControl = Kp_vel * error_vel_right + Ki_vel * integral_right;

    float pwmLeft_val = basePwm - leftControl;
    float pwmRight_val = basePwm - rightControl;

    if(pwmLeft_val > maxPwm) pwmLeft_val = maxPwm;
    if(pwmLeft_val < minPwm) pwmLeft_val = minPwm;

    if(pwmRight_val > maxPwm) pwmRight_val = maxPwm;
    if(pwmRight_val < minPwm) pwmRight_val = minPwm;

    pwmLeft.write(pwmLeft_val);
    pwmRight.write(pwmRight_val);
    enable = 1;

    preverror_pos = error_pos;
}

int main()
{
    rightPol = 0;
    leftPol = 0;
    enable = 0;

    state = startUp;
    lastState = controlState;

    hm10.baud(9600);
    hm10.attach(&bluetoothIRS, SerialBase::RxIrq);

    mpu.setSleepMode(false);

    Timer imuTimer;

    while(true) {

        if(do180Turn == true){

            yaw = 0.0f;

            directionRight = 1;
            directionLeft = 0;
            enable = 1;

            imuTimer.reset();
            imuTimer.start();

            while(!turnCheck180()){

                pwmLeft.write(0.6f);
                pwmRight.write(0.6f);

                float data[3];
                mpu.getGyro(data);

                zGyro = data[2];
                yaw += zGyro * 0.01f;

                wait_ms(10);
            }

            stop_motors();
            do180Turn = false;
            state = controlState;
        }

        switch(state) {

            case startUp:
                if(state != lastState){
                    enable = 0;
                    pwmRight.write(1.0f);
                    pwmLeft.write(1.0f);

                    lcd.cls();
                    lcd.locate(0,0);
                    lcd.printf("Start Screen");

                    integral_left = 0.0f;
                    integral_right = 0.0f;
                    preverror_pos = 0.0f;
                    stopCountCheck = 0;
                }

                lastState = startUp;
                break;

            case preControl:
                if(state != lastState){
                    lcd.cls();
                    lcd.locate(0,0);
                    lcd.printf("Pre Control State");

                    pwmRight.write(0.62f);
                    pwmLeft.write(0.62f);
                    enable = 1;

                    wait_ms(500);

                    state = turnaroundState;
                }

                lastState = preControl;
                break;

            case turnaroundState:
                if(state != lastState){
                    lcd.cls();
                    lcd.locate(0,0);
                    lcd.printf("Turning 180");

                    do180Turn = true;
                }

                lastState = turnaroundState;
                break;

            case controlState:
                controller();
                lastState = controlState;
                break;
        }
    }
}
